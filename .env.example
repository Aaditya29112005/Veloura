# Database connection URL for Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5435/fashion_db?schema=public"

# Secret key for JWT signing and verification
JWT_SECRET="super-secret-jwt-key-change-in-prod"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudinary credentials (optional, fallback to base64 mock is supported)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
